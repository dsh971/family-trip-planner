# ── Required ────────────────────────────────────────────────────────────────

# Google Cloud project with Places API AND Routes API enabled.
# Places API: used for geocoding, place search, and corroboration (U5/U6).
# Routes API: used for detour transit routing (U9, KTD-I).
# Both share the same key and billing project.
# Note: the flat $200/month credit was removed in March 2025 — check per-SKU
# free-tier limits at console.cloud.google.com before assuming zero cost.
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Custom Search Engine ID.
# Used for the web-search discovery layer (U6, KTD-C) — 100 free queries/day.
# 1. Enable "Custom Search API" in your Google Cloud project (same project as Places).
# 2. Create a search engine at programmablesearchengine.google.com configured to
#    search the entire web, then copy its ID (cx) here.
# The API key is shared with GOOGLE_PLACES_API_KEY above — no separate key needed.
GOOGLE_CSE_CX=your_custom_search_engine_id_here

# ── Strongly recommended for Japan coverage ─────────────────────────────────

# Hotpepper (Recruit) Japan restaurant platform API.
# Without this key, Wanderlust GOAT falls back to HTML scraping of Hotpepper
# (fragile and ToS-risky). This key is what makes cross-source corroboration
# scores non-zero for Tokyo restaurants (see curation engine plan, KTD-C risk).
HOTPEPPER_API_KEY=your_hotpepper_api_key_here

# ── Optional / overrides ────────────────────────────────────────────────────

# SQLite database file path.
# Default (local dev): ./local.db
# Docker default (set in Dockerfile): /data/local.db — mount /data as a named
# volume so the DB persists across container restarts.
# DATABASE_URL=./local.db

# Next.js server port (default: 3000)
# PORT=3000
