# Required — Google Cloud project with Places API and Routes API enabled
GOOGLE_PLACES_API_KEY=

# Required for U6 discovery (web search candidate breadth)
# Obtain at: https://serper.dev
SERPER_API_KEY=

# Optional but strongly recommended for Tokyo coverage
# Hotpepper (Recruit) restaurant platform — improves WG corroboration scores for Japan
HOTPEPPER_API_KEY=

# SQLite database path (defaults to ./local.db if unset)
DATABASE_URL=./local.db
